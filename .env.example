# Root environment configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ──────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/stockpilot

# ──────────────────────────────────────────────────────────────────
# Redis (for distributed rate limiting)
# ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────────
# JWT & Authentication
# ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────────────────────────────
# Auth Lockout Policy (see apps/api/src/lib/rate-limit.ts)
# ──────────────────────────────────────────────────────────────────
AUTH_LOCKOUT_ACCOUNT_THRESHOLD=5
AUTH_LOCKOUT_IP_THRESHOLD=20
AUTH_LOCKOUT_WINDOW_MS=900000
AUTH_LOCKOUT_DURATION_MS=1800000

# ──────────────────────────────────────────────────────────────────
# API Configuration
# ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NODE_ENV=development

# ──────────────────────────────────────────────────────────────────
# Client Configuration
# ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000
VITE_APP_NAME=StockPilot Pro
