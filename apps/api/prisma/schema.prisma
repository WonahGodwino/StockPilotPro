// This is your Prisma schema file
// Learn more about it at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  AGENT
  BUSINESS_ADMIN
  SALESPERSON
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum SubscriptionChangeType {
  NEW
  RENEW
  UPGRADE
}

enum SubscriptionPaymentMethod {
  PAYSTACK
  TRANSFER
  MANUAL
}

enum SubscriptionTransactionStatus {
  PENDING_PAYMENT
  PENDING_VERIFICATION
  VERIFIED
  ACTIVE
  REJECTED
  CANCELLED
}

enum AgentCommissionPaymentStatus {
  PENDING
  PAID
}

enum ProductType {
  GOODS
  SERVICE
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  POS
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

// ──────────────────────────────────────────────
// PLANS (created by SUPER_ADMIN)
// ──────────────────────────────────────────────

model Plan {
  id                   String       @id @default(cuid())
  name                 String
  description          String?
  price                Decimal      @db.Decimal(12, 2)
  priceCurrency        String       @default("USD")
  billingCycle         BillingCycle @default(MONTHLY)
  maxSubsidiaries      Int          @default(1)
  extraSubsidiaryPrice Decimal      @db.Decimal(12, 2) @default(0)
  features             Json         @default("[]")
  isActive             Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  createdBy            String?
  updatedBy            String?

  subscriptions   Subscription[]
  currentPlanTransactions   SubscriptionTransaction[] @relation("CurrentPlanTransaction")
  requestedPlanTransactions SubscriptionTransaction[] @relation("RequestedPlanTransaction")
}

model TrustedCustomer {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?
  websiteUrl  String?
  displayOrder Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  @@index([isActive, displayOrder])
}

// ──────────────────────────────────────────────
// TENANTS (each = one business)
// ──────────────────────────────────────────────

model Tenant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  email           String   @unique
  phone           String?
  address         String?
  country         String?
  state           String?
  lga             String?
  logo            String?
  baseCurrency    String   @default("USD")
  presenceTimeoutMinutes Int @default(2)
  isActive        Boolean  @default(true)
  ssoEnabled      Boolean  @default(false)
  ssoProviders    Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?
  acquisitionAgentId String?
  archived        Boolean  @default(false)

  acquisitionAgent User?   @relation("AgentTenants", fields: [acquisitionAgentId], references: [id], onDelete: SetNull)

  users           User[]
  subsidiaries    Subsidiary[]
  products        Product[]
  sales           Sale[]
  expenses        Expense[]
  damageRecords   DamageRecord[]
  subscriptions   Subscription[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  ssoAccounts     SsoAccount[]
  currencyRates   CurrencyRate[]
  syncTelemetry   SyncTelemetry[]
  subscriptionTransactions SubscriptionTransaction[]

  @@index([acquisitionAgentId])
}

// ──────────────────────────────────────────────
// SUBSCRIPTIONS
// ──────────────────────────────────────────────

model Subscription {
  id              String             @id @default(cuid())
  tenantId        String
  planId          String
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime
  expiryDate      DateTime
  amount          Decimal            @db.Decimal(12, 2)
  billingCurrency String             @default("USD")
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       String?
  updatedBy       String?

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan            Plan               @relation(fields: [planId], references: [id])
  transactions    SubscriptionTransaction[]

  @@index([tenantId])
  @@index([status])
}

model SubscriptionTransaction {
  id                      String                        @id @default(cuid())
  tenantId                String
  subscriptionId          String?
  currentPlanId           String?
  requestedPlanId         String
  changeType              SubscriptionChangeType
  paymentMethod           SubscriptionPaymentMethod
  billingCycle            BillingCycle
  amount                  Decimal                       @db.Decimal(12, 2)
  currency                String                        @default("USD")
  status                  SubscriptionTransactionStatus @default(PENDING_PAYMENT)
  paystackReference       String?                       @unique
  paystackAccessCode      String?
  paymentProviderResponse Json?
  transferProofUrl        String?
  transferProofOriginalName String?
  transferProofSize       Int?
  transferProofContentType String?
  transferProofUploadedByUserId String?
  transferProofUploadedAt DateTime?
  transferProofNote       String?
  initiatedByUserId       String?
  verifiedByUserId        String?
  activatedByUserId       String?
  modifiedByUserId        String?
  initiatedAt             DateTime                      @default(now())
  verifiedAt              DateTime?
  activatedAt             DateTime?
  modifiedAt              DateTime?
  lifecycleEvents         Json                          @default("[]")
  notes                   String?
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt

  tenant                  Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription            Subscription?                 @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  currentPlan             Plan?                         @relation("CurrentPlanTransaction", fields: [currentPlanId], references: [id], onDelete: SetNull)
  requestedPlan           Plan                          @relation("RequestedPlanTransaction", fields: [requestedPlanId], references: [id])
  initiatedBy             User?                         @relation("SubscriptionInitiatedBy", fields: [initiatedByUserId], references: [id], onDelete: SetNull)
  verifiedBy              User?                         @relation("SubscriptionVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  activatedBy             User?                         @relation("SubscriptionActivatedBy", fields: [activatedByUserId], references: [id], onDelete: SetNull)
  modifiedBy              User?                         @relation("SubscriptionModifiedBy", fields: [modifiedByUserId], references: [id], onDelete: SetNull)
  transferProofUploader   User?                         @relation("SubscriptionTransferProofUploader", fields: [transferProofUploadedByUserId], references: [id], onDelete: SetNull)
  commissionRemittance    AgentCommissionRemittance?

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([status, createdAt])
}

// ──────────────────────────────────────────────
// USERS
// ──────────────────────────────────────────────

model User {
  id              String       @id @default(cuid())
  tenantId        String?
  subsidiaryId    String?
  email           String       @unique
  password        String?
  firstName       String
  lastName        String
  role            UserRole
  phone           String?
  isActive        Boolean      @default(true)
  lastLoginAt     DateTime?
  lastSeenAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean      @default(false)

  tenant          Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary      Subsidiary?  @relation(fields: [subsidiaryId], references: [id])
  sales           Sale[]
  expenses        Expense[]
  damageRecords   DamageRecord[] @relation("DamageRecords")
  refreshTokens   RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  ssoAccounts     SsoAccount[]
  syncTelemetry   SyncTelemetry[]
  initiatedSubscriptionTransactions SubscriptionTransaction[] @relation("SubscriptionInitiatedBy")
  verifiedSubscriptionTransactions  SubscriptionTransaction[] @relation("SubscriptionVerifiedBy")
  activatedSubscriptionTransactions SubscriptionTransaction[] @relation("SubscriptionActivatedBy")
  modifiedSubscriptionTransactions  SubscriptionTransaction[] @relation("SubscriptionModifiedBy")
  uploadedSubscriptionTransferProofs SubscriptionTransaction[] @relation("SubscriptionTransferProofUploader")
  remittedAgentCommissions AgentCommissionRemittance[] @relation("AgentCommissionRemittedBy")
  assignedTenants Tenant[] @relation("AgentTenants")

  @@index([tenantId])
  @@index([email])
  @@index([role])
  @@index([lastSeenAt])
}

model AgentCommissionRemittance {
  id                        String                       @id @default(cuid())
  subscriptionTransactionId String                       @unique
  status                    AgentCommissionPaymentStatus @default(PAID)
  batchId                   String?
  cycleStartAt              DateTime?
  cycleEndAt                DateTime?
  paidAt                    DateTime?
  paidByUserId              String?
  reportFileName            String?
  source                    String?
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt

  subscriptionTransaction   SubscriptionTransaction      @relation(fields: [subscriptionTransactionId], references: [id], onDelete: Cascade)
  paidBy                    User?                        @relation("AgentCommissionRemittedBy", fields: [paidByUserId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([cycleStartAt, cycleEndAt])
  @@index([status, updatedAt])
  @@index([paidByUserId])
}

// ──────────────────────────────────────────────
// SSO ACCOUNTS (linked OAuth identities)
// ──────────────────────────────────────────────

model SsoAccount {
  id              String   @id @default(cuid())
  userId          String
  tenantId        String
  provider        String   // google | microsoft
  providerUserId  String
  email           String
  displayName     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([provider, userId])
  @@index([userId])
  @@index([tenantId])
}

// ──────────────────────────────────────────────
// REFRESH TOKENS
// ──────────────────────────────────────────────

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  email      String
  tokenHash  String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([expiresAt])
}

// ──────────────────────────────────────────────
// SUBSIDIARIES (BRANCHES)
// ──────────────────────────────────────────────

model Subsidiary {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  address         String?
  phone           String?
  email           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean   @default(false)

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  products        Product[]
  sales           Sale[]
  expenses        Expense[]
  damageRecords   DamageRecord[]
  syncTelemetry   SyncTelemetry[]

  @@index([tenantId])
}

// ──────────────────────────────────────────────
// PRODUCTS / SERVICES
// ──────────────────────────────────────────────

model Product {
  id                  String        @id @default(cuid())
  tenantId            String
  subsidiaryId        String
  name                String
  description         String?
  type                ProductType   @default(GOODS)
  unit                String        @default("pcs")
  quantity            Decimal       @db.Decimal(12, 3) @default(0)
  costPrice           Decimal       @db.Decimal(12, 2)
  sellingPrice        Decimal       @db.Decimal(12, 2)
  barcode             String?
  lowStockThreshold   Decimal       @db.Decimal(12, 3) @default(10)
  expiryDate          DateTime?
  status              ProductStatus @default(ACTIVE)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  createdBy           String?
  updatedBy           String?
  archived            Boolean       @default(false)

  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary          Subsidiary    @relation(fields: [subsidiaryId], references: [id])
  saleItems           SaleItem[]
  damageRecords       DamageRecord[]
  notifications       Notification[]

  @@index([tenantId])
  @@index([subsidiaryId])
  @@index([barcode])
  @@index([status])
  @@index([expiryDate])
}

// ──────────────────────────────────────────────
// SALES
// ──────────────────────────────────────────────

model Sale {
  id              String        @id @default(cuid())
  tenantId        String
  subsidiaryId    String
  userId          String
  totalAmount     Decimal       @db.Decimal(12, 2)
  discount        Decimal       @db.Decimal(12, 2) @default(0)
  amountPaid      Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @default(CASH)
  receiptNumber   String        @unique
  currency        String        @default("USD")
  fxRate          Decimal       @db.Decimal(18, 8) @default(1)
  syncRef         String?
  transactionRef  String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean       @default(false)

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary      Subsidiary    @relation(fields: [subsidiaryId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
  items           SaleItem[]

  @@index([tenantId])
  @@index([subsidiaryId])
  @@index([userId])
  @@index([createdAt])
  @@unique([tenantId, syncRef])
  @@unique([tenantId, transactionRef])
}

// ──────────────────────────────────────────────
// SALE ITEMS
// ──────────────────────────────────────────────

model SaleItem {
  id              String    @id @default(cuid())
  saleId          String
  productId       String
  quantity        Decimal   @db.Decimal(12, 3)
  unitPrice       Decimal   @db.Decimal(12, 2)
  costPrice       Decimal   @db.Decimal(12, 2)
  discount        Decimal   @db.Decimal(12, 2) @default(0)
  subtotal        Decimal   @db.Decimal(12, 2)

  sale            Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

// ──────────────────────────────────────────────
// EXPENSES
// ──────────────────────────────────────────────

model Expense {
  id              String    @id @default(cuid())
  tenantId        String
  subsidiaryId    String?
  userId          String
  title           String
  amount          Decimal   @db.Decimal(12, 2)
  category        String
  date            DateTime
  currency        String    @default("USD")
  fxRate          Decimal   @db.Decimal(18, 8) @default(1)
  syncRef         String?
  transactionRef  String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean   @default(false)

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary      Subsidiary? @relation(fields: [subsidiaryId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([subsidiaryId])
  @@index([date])
  @@unique([tenantId, syncRef])
  @@unique([tenantId, transactionRef])
}

model SyncTelemetry {
  id            String    @id @default(cuid())
  tenantId      String
  subsidiaryId  String?
  userId        String?
  deviceId      String
  source        String    @default("web")
  status        String
  pendingBefore Int       @default(0)
  syncedCount   Int       @default(0)
  failedCount   Int       @default(0)
  error         String?
  createdAt     DateTime  @default(now())

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary    Subsidiary? @relation(fields: [subsidiaryId], references: [id], onDelete: SetNull)
  user          User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, deviceId, createdAt])
  @@index([tenantId, status, createdAt])
}

// ──────────────────────────────────────────────
// DAMAGE RECORDS (Damaged/Expired Goods)
// ──────────────────────────────────────────────

model DamageRecord {
  id              String    @id @default(cuid())
  tenantId        String
  subsidiaryId    String
  productId       String
  userId          String
  quantity        Decimal   @db.Decimal(12, 3)
  unit            String    @default("pcs")
  reason          String    // EXPIRED | DAMAGED | LOST | RAW_MATERIAL_DAMAGE | OTHER
  damageStage     String    @default("FINISHED_GOODS") // FINISHED_GOODS | RAW_MATERIAL
  description     String?
  cost            Decimal   @db.Decimal(12, 2) // Total cost: selling price for finished goods, cost price for raw materials
  date            DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  updatedBy       String?

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary      Subsidiary @relation(fields: [subsidiaryId], references: [id])
  product         Product   @relation(fields: [productId], references: [id])
  user            User      @relation("DamageRecords", fields: [userId], references: [id])

  @@index([tenantId])
  @@index([subsidiaryId])
  @@index([productId])
  @@index([date])
}

// ──────────────────────────────────────────────
// NOTIFICATIONS
// ──────────────────────────────────────────────

model Notification {
  id              String    @id @default(cuid())
  tenantId        String
  subsidiaryId    String?
  productId       String?
  type            String    // LOW_STOCK | SUBSCRIPTION_EXPIRING | SYSTEM
  title           String
  message         String
  isRead          Boolean   @default(false)
  createdAt       DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product         Product?  @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([isRead])
}

// ──────────────────────────────────────────────
// AUDIT LOGS
// ──────────────────────────────────────────────

model AuditLog {
  id              String    @id @default(cuid())
  tenantId        String
  userId          String?
  action          String    // CREATE | UPDATE | DELETE | LOGIN | LOGOUT
  entity          String    // product | sale | expense | user | ...
  entityId        String?
  oldValues       Json?
  newValues       Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// CURRENCY RATES (FX snapshots per tenant)
// ──────────────────────────────────────────────

model CurrencyRate {
  id           String   @id @default(cuid())
  tenantId     String
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(18, 8)
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  createdBy    String?

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([date])
  @@index([fromCurrency, toCurrency])
}
