// This is your Prisma schema file
// Learn more about it at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  BUSINESS_ADMIN
  SALESPERSON
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum ProductType {
  GOODS
  SERVICE
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  POS
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

// ──────────────────────────────────────────────
// PLANS (created by SUPER_ADMIN)
// ──────────────────────────────────────────────

model Plan {
  id                   String       @id @default(cuid())
  name                 String
  description          String?
  price                Decimal      @db.Decimal(12, 2)
  priceCurrency        String       @default("USD")
  billingCycle         BillingCycle @default(MONTHLY)
  maxSubsidiaries      Int          @default(1)
  extraSubsidiaryPrice Decimal      @db.Decimal(12, 2) @default(0)
  features             Json         @default("[]")
  isActive             Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  createdBy            String?
  updatedBy            String?

  subscriptions   Subscription[]
}

// ──────────────────────────────────────────────
// TENANTS (each = one business)
// ──────────────────────────────────────────────

model Tenant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  email           String   @unique
  phone           String?
  address         String?
  logo            String?
  baseCurrency    String   @default("USD")
  isActive        Boolean  @default(true)
  ssoEnabled      Boolean  @default(false)
  ssoProviders    Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean  @default(false)

  users           User[]
  subsidiaries    Subsidiary[]
  products        Product[]
  sales           Sale[]
  expenses        Expense[]
  damageRecords   DamageRecord[]
  subscriptions   Subscription[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  ssoAccounts     SsoAccount[]
  currencyRates   CurrencyRate[]
  syncTelemetry   SyncTelemetry[]
}

// ──────────────────────────────────────────────
// SUBSCRIPTIONS
// ──────────────────────────────────────────────

model Subscription {
  id              String             @id @default(cuid())
  tenantId        String
  planId          String
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime
  expiryDate      DateTime
  amount          Decimal            @db.Decimal(12, 2)
  billingCurrency String             @default("USD")
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       String?
  updatedBy       String?

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan            Plan               @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([status])
}

// ──────────────────────────────────────────────
// USERS
// ──────────────────────────────────────────────

model User {
  id              String       @id @default(cuid())
  tenantId        String?
  subsidiaryId    String?
  email           String       @unique
  password        String?
  firstName       String
  lastName        String
  role            UserRole
  phone           String?
  isActive        Boolean      @default(true)
  lastLoginAt     DateTime?
  lastSeenAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean      @default(false)

  tenant          Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary      Subsidiary?  @relation(fields: [subsidiaryId], references: [id])
  sales           Sale[]
  expenses        Expense[]
  damageRecords   DamageRecord[] @relation("DamageRecords")
  refreshTokens   RefreshToken[]
  ssoAccounts     SsoAccount[]
  syncTelemetry   SyncTelemetry[]

  @@index([tenantId])
  @@index([email])
  @@index([role])
  @@index([lastSeenAt])
}

// ──────────────────────────────────────────────
// SSO ACCOUNTS (linked OAuth identities)
// ──────────────────────────────────────────────

model SsoAccount {
  id              String   @id @default(cuid())
  userId          String
  tenantId        String
  provider        String   // google | microsoft
  providerUserId  String
  email           String
  displayName     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([provider, userId])
  @@index([userId])
  @@index([tenantId])
}

// ──────────────────────────────────────────────
// REFRESH TOKENS
// ──────────────────────────────────────────────

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ──────────────────────────────────────────────
// SUBSIDIARIES (BRANCHES)
// ──────────────────────────────────────────────

model Subsidiary {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  address         String?
  phone           String?
  email           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean   @default(false)

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  products        Product[]
  sales           Sale[]
  expenses        Expense[]
  damageRecords   DamageRecord[]
  syncTelemetry   SyncTelemetry[]

  @@index([tenantId])
}

// ──────────────────────────────────────────────
// PRODUCTS / SERVICES
// ──────────────────────────────────────────────

model Product {
  id                  String        @id @default(cuid())
  tenantId            String
  subsidiaryId        String
  name                String
  description         String?
  type                ProductType   @default(GOODS)
  unit                String        @default("pcs")
  quantity            Decimal       @db.Decimal(12, 3) @default(0)
  costPrice           Decimal       @db.Decimal(12, 2)
  sellingPrice        Decimal       @db.Decimal(12, 2)
  barcode             String?
  lowStockThreshold   Decimal       @db.Decimal(12, 3) @default(10)
  expiryDate          DateTime?
  status              ProductStatus @default(ACTIVE)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  createdBy           String?
  updatedBy           String?
  archived            Boolean       @default(false)

  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary          Subsidiary    @relation(fields: [subsidiaryId], references: [id])
  saleItems           SaleItem[]
  damageRecords       DamageRecord[]
  notifications       Notification[]

  @@index([tenantId])
  @@index([subsidiaryId])
  @@index([barcode])
  @@index([status])
  @@index([expiryDate])
}

// ──────────────────────────────────────────────
// SALES
// ──────────────────────────────────────────────

model Sale {
  id              String        @id @default(cuid())
  tenantId        String
  subsidiaryId    String
  userId          String
  totalAmount     Decimal       @db.Decimal(12, 2)
  discount        Decimal       @db.Decimal(12, 2) @default(0)
  amountPaid      Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @default(CASH)
  receiptNumber   String        @unique
  currency        String        @default("USD")
  fxRate          Decimal       @db.Decimal(18, 8) @default(1)
  syncRef         String?
  transactionRef  String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean       @default(false)

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary      Subsidiary    @relation(fields: [subsidiaryId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
  items           SaleItem[]

  @@index([tenantId])
  @@index([subsidiaryId])
  @@index([userId])
  @@index([createdAt])
  @@unique([tenantId, syncRef])
  @@unique([tenantId, transactionRef])
}

// ──────────────────────────────────────────────
// SALE ITEMS
// ──────────────────────────────────────────────

model SaleItem {
  id              String    @id @default(cuid())
  saleId          String
  productId       String
  quantity        Decimal   @db.Decimal(12, 3)
  unitPrice       Decimal   @db.Decimal(12, 2)
  costPrice       Decimal   @db.Decimal(12, 2)
  discount        Decimal   @db.Decimal(12, 2) @default(0)
  subtotal        Decimal   @db.Decimal(12, 2)

  sale            Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

// ──────────────────────────────────────────────
// EXPENSES
// ──────────────────────────────────────────────

model Expense {
  id              String    @id @default(cuid())
  tenantId        String
  subsidiaryId    String
  userId          String
  title           String
  amount          Decimal   @db.Decimal(12, 2)
  category        String
  date            DateTime
  currency        String    @default("USD")
  fxRate          Decimal   @db.Decimal(18, 8) @default(1)
  syncRef         String?
  transactionRef  String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean   @default(false)

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary      Subsidiary @relation(fields: [subsidiaryId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([subsidiaryId])
  @@index([date])
  @@unique([tenantId, syncRef])
  @@unique([tenantId, transactionRef])
}

model SyncTelemetry {
  id            String    @id @default(cuid())
  tenantId      String
  subsidiaryId  String?
  userId        String?
  deviceId      String
  source        String    @default("web")
  status        String
  pendingBefore Int       @default(0)
  syncedCount   Int       @default(0)
  failedCount   Int       @default(0)
  error         String?
  createdAt     DateTime  @default(now())

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary    Subsidiary? @relation(fields: [subsidiaryId], references: [id], onDelete: SetNull)
  user          User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, deviceId, createdAt])
  @@index([tenantId, status, createdAt])
}

// ──────────────────────────────────────────────
// DAMAGE RECORDS (Damaged/Expired Goods)
// ──────────────────────────────────────────────

model DamageRecord {
  id              String    @id @default(cuid())
  tenantId        String
  subsidiaryId    String
  productId       String
  userId          String
  quantity        Decimal   @db.Decimal(12, 3)
  unit            String    @default("pcs")
  reason          String    // EXPIRED | DAMAGED | LOST | RAW_MATERIAL_DAMAGE | OTHER
  damageStage     String    @default("FINISHED_GOODS") // FINISHED_GOODS | RAW_MATERIAL
  description     String?
  cost            Decimal   @db.Decimal(12, 2) // Total cost: selling price for finished goods, cost price for raw materials
  date            DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  updatedBy       String?

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary      Subsidiary @relation(fields: [subsidiaryId], references: [id])
  product         Product   @relation(fields: [productId], references: [id])
  user            User      @relation("DamageRecords", fields: [userId], references: [id])

  @@index([tenantId])
  @@index([subsidiaryId])
  @@index([productId])
  @@index([date])
}

// ──────────────────────────────────────────────
// NOTIFICATIONS
// ──────────────────────────────────────────────

model Notification {
  id              String    @id @default(cuid())
  tenantId        String
  subsidiaryId    String?
  productId       String?
  type            String    // LOW_STOCK | SUBSCRIPTION_EXPIRING | SYSTEM
  title           String
  message         String
  isRead          Boolean   @default(false)
  createdAt       DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product         Product?  @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([isRead])
}

// ──────────────────────────────────────────────
// AUDIT LOGS
// ──────────────────────────────────────────────

model AuditLog {
  id              String    @id @default(cuid())
  tenantId        String
  userId          String?
  action          String    // CREATE | UPDATE | DELETE | LOGIN | LOGOUT
  entity          String    // product | sale | expense | user | ...
  entityId        String?
  oldValues       Json?
  newValues       Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// CURRENCY RATES (FX snapshots per tenant)
// ──────────────────────────────────────────────

model CurrencyRate {
  id           String   @id @default(cuid())
  tenantId     String
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(18, 8)
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  createdBy    String?

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([date])
  @@index([fromCurrency, toCurrency])
}
