// This is your Prisma schema file
// Learn more about it at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  BUSINESS_ADMIN
  SALESPERSON
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum ProductType {
  GOODS
  SERVICE
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  POS
}

// ──────────────────────────────────────────────
// PLANS (created by SUPER_ADMIN)
// ──────────────────────────────────────────────

model Plan {
  id              String   @id @default(cuid())
  name            String
  description     String?
  price           Decimal  @db.Decimal(12, 2)
  maxSubsidiaries Int      @default(1)
  extraSubsidiaryPrice Decimal @db.Decimal(12, 2) @default(0)
  features        Json     @default("{}")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?

  subscriptions   Subscription[]
}

// ──────────────────────────────────────────────
// TENANTS (each = one business)
// ──────────────────────────────────────────────

model Tenant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  email           String   @unique
  phone           String?
  address         String?
  logo            String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean  @default(false)

  users           User[]
  subsidiaries    Subsidiary[]
  products        Product[]
  sales           Sale[]
  expenses        Expense[]
  subscriptions   Subscription[]
  notifications   Notification[]
  auditLogs       AuditLog[]
}

// ──────────────────────────────────────────────
// SUBSCRIPTIONS
// ──────────────────────────────────────────────

model Subscription {
  id              String             @id @default(cuid())
  tenantId        String
  planId          String
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime
  expiryDate      DateTime
  amount          Decimal            @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       String?
  updatedBy       String?

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan            Plan               @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([status])
}

// ──────────────────────────────────────────────
// USERS
// ──────────────────────────────────────────────

model User {
  id              String       @id @default(cuid())
  tenantId        String?
  subsidiaryId    String?
  email           String       @unique
  password        String
  firstName       String
  lastName        String
  role            UserRole
  phone           String?
  isActive        Boolean      @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean      @default(false)

  tenant          Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary      Subsidiary?  @relation(fields: [subsidiaryId], references: [id])
  sales           Sale[]
  expenses        Expense[]
  refreshTokens   RefreshToken[]

  @@index([tenantId])
  @@index([email])
  @@index([role])
}

// ──────────────────────────────────────────────
// REFRESH TOKENS
// ──────────────────────────────────────────────

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ──────────────────────────────────────────────
// SUBSIDIARIES (BRANCHES)
// ──────────────────────────────────────────────

model Subsidiary {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  address         String?
  phone           String?
  email           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean   @default(false)

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  products        Product[]
  sales           Sale[]
  expenses        Expense[]

  @@index([tenantId])
}

// ──────────────────────────────────────────────
// PRODUCTS / SERVICES
// ──────────────────────────────────────────────

model Product {
  id                  String        @id @default(cuid())
  tenantId            String
  subsidiaryId        String
  name                String
  description         String?
  type                ProductType   @default(GOODS)
  unit                String        @default("pcs")
  quantity            Decimal       @db.Decimal(12, 3) @default(0)
  costPrice           Decimal       @db.Decimal(12, 2)
  sellingPrice        Decimal       @db.Decimal(12, 2)
  barcode             String?
  lowStockThreshold   Decimal       @db.Decimal(12, 3) @default(10)
  status              ProductStatus @default(ACTIVE)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  createdBy           String?
  updatedBy           String?
  archived            Boolean       @default(false)

  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary          Subsidiary    @relation(fields: [subsidiaryId], references: [id])
  saleItems           SaleItem[]
  notifications       Notification[]

  @@index([tenantId])
  @@index([subsidiaryId])
  @@index([barcode])
  @@index([status])
}

// ──────────────────────────────────────────────
// SALES
// ──────────────────────────────────────────────

model Sale {
  id              String        @id @default(cuid())
  tenantId        String
  subsidiaryId    String
  userId          String
  totalAmount     Decimal       @db.Decimal(12, 2)
  discount        Decimal       @db.Decimal(12, 2) @default(0)
  amountPaid      Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @default(CASH)
  receiptNumber   String        @unique
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean       @default(false)

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary      Subsidiary    @relation(fields: [subsidiaryId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
  items           SaleItem[]

  @@index([tenantId])
  @@index([subsidiaryId])
  @@index([userId])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// SALE ITEMS
// ──────────────────────────────────────────────

model SaleItem {
  id              String    @id @default(cuid())
  saleId          String
  productId       String
  quantity        Decimal   @db.Decimal(12, 3)
  unitPrice       Decimal   @db.Decimal(12, 2)
  costPrice       Decimal   @db.Decimal(12, 2)
  discount        Decimal   @db.Decimal(12, 2) @default(0)
  subtotal        Decimal   @db.Decimal(12, 2)

  sale            Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

// ──────────────────────────────────────────────
// EXPENSES
// ──────────────────────────────────────────────

model Expense {
  id              String    @id @default(cuid())
  tenantId        String
  subsidiaryId    String
  userId          String
  title           String
  amount          Decimal   @db.Decimal(12, 2)
  category        String
  date            DateTime
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  updatedBy       String?
  archived        Boolean   @default(false)

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subsidiary      Subsidiary @relation(fields: [subsidiaryId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([subsidiaryId])
  @@index([date])
}

// ──────────────────────────────────────────────
// NOTIFICATIONS
// ──────────────────────────────────────────────

model Notification {
  id              String    @id @default(cuid())
  tenantId        String
  subsidiaryId    String?
  productId       String?
  type            String    // LOW_STOCK | SUBSCRIPTION_EXPIRING | SYSTEM
  title           String
  message         String
  isRead          Boolean   @default(false)
  createdAt       DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product         Product?  @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([isRead])
}

// ──────────────────────────────────────────────
// AUDIT LOGS
// ──────────────────────────────────────────────

model AuditLog {
  id              String    @id @default(cuid())
  tenantId        String
  userId          String?
  action          String    // CREATE | UPDATE | DELETE | LOGIN | LOGOUT
  entity          String    // product | sale | expense | user | ...
  entityId        String?
  oldValues       Json?
  newValues       Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}
