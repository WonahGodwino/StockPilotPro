DATABASE_URL="postgresql://postgres:password@localhost:5432/stockpilot_pro"
REDIS_URL="redis://localhost:6379"

JWT_SECRET="change-this-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-this-refresh-to-a-random-64-char-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Auth lockout policy
AUTH_LOCKOUT_ACCOUNT_THRESHOLD="8"
AUTH_LOCKOUT_IP_THRESHOLD="20"
AUTH_LOCKOUT_WINDOW_MS="900000"
AUTH_LOCKOUT_DURATION_MS="1800000"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
ALLOWED_ORIGIN="http://localhost:5173"
