# ──────────────────────────────────────────────────────────────────
# Database Configuration
# ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost/stockpilot_pro

# ──────────────────────────────────────────────────────────────────
# Redis Configuration (for distributed rate limiting)
# ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────────
# JWT & Authentication Secrets
# ⚠️ IMPORTANT: Generate strong random secrets for production
# Min 32 characters, alphanumeric with special characters
# ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────────────────────────────
# Auth Lockout Policy Configuration
# Configurable failure thresholds for account/IP lockout
# ──────────────────────────────────────────────────────────────────
AUTH_LOCKOUT_ACCOUNT_THRESHOLD=5
AUTH_LOCKOUT_IP_THRESHOLD=20
AUTH_LOCKOUT_WINDOW_MS=900000
AUTH_LOCKOUT_DURATION_MS=1800000

# ──────────────────────────────────────────────────────────────────
# Application URLs
# ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ALLOWED_ORIGIN=http://localhost:5173
NODE_ENV=development
