# Paystack integration
# Set when credentials are available
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_CALLBACK_URL=

# Enterprise Assistant (External LLM - optional)
ENTERPRISE_AI_EXTERNAL_LLM_ENABLED=false
ENTERPRISE_AI_LLM_PROVIDER="openai-compatible"
ENTERPRISE_AI_LLM_API_KEY=
ENTERPRISE_AI_LLM_BASE_URL="https://api.openai.com/v1"
ENTERPRISE_AI_LLM_MODEL="gpt-4o-mini"
ENTERPRISE_AI_LLM_MODEL_FALLBACK="gpt-4o-mini"
ENTERPRISE_AI_LLM_TIMEOUT_MS=20000
ENTERPRISE_AI_LLM_MAX_RETRIES=2

# Azure OpenAI (optional alternative provider)
ENTERPRISE_AI_AZURE_ENDPOINT=
ENTERPRISE_AI_AZURE_DEPLOYMENT=
ENTERPRISE_AI_AZURE_API_VERSION="2024-06-01"

# Enterprise AI scheduled refresh jobs
ENTERPRISE_AI_JOB_SECRET=
ENTERPRISE_AI_JOB_TENANT_LIMIT=20
ENTERPRISE_AI_JOB_STALE_MINUTES=45
ENTERPRISE_AI_STALE_CONTEXT_HOURS=48
ENTERPRISE_AI_PRECOMPUTE_MIN_TX_COUNT=120

# Enterprise AI alert fatigue controls
ENTERPRISE_AI_ALERT_MIN_PRIORITY="P3"
ENTERPRISE_AI_ALERT_QUIET_START_UTC=
ENTERPRISE_AI_ALERT_QUIET_END_UTC=
ENTERPRISE_AI_ALERT_ACK_SUPPRESS_HOURS=24
ENTERPRISE_AI_ALERT_DEDUPE_HOURS_P1=2
ENTERPRISE_AI_ALERT_DEDUPE_HOURS_P2=8
ENTERPRISE_AI_ALERT_DEDUPE_HOURS_P3=24
