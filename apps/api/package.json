{
  "name": "stockpilot-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:rbac": "ts-node -P tests/tsconfig.json tests/rbac.spec.ts",
    "test:jwt": "ts-node -P tests/tsconfig.json tests/jwt.spec.ts",
    "test:observability": "ts-node -P tests/tsconfig.json tests/observability.spec.ts",
    "test:sso": "ts-node -P tests/tsconfig.json tests/sso.spec.ts",
    "test:subscription": "ts-node -P tests/tsconfig.json tests/subscription.spec.ts",
    "test:tenants": "ts-node -P tests/tsconfig.json tests/tenants.spec.ts",
    "test:customer-loyalty": "ts-node -r tsconfig-paths/register -P tests/tsconfig.json tests/customer-loyalty.spec.ts",
    "test:currency": "ts-node -P tests/tsconfig.json tests/currency.spec.ts",
    "test:enterprise-ai": "ts-node -P tests/tsconfig.json tests/enterprise-ai.spec.ts",
    "test:enterprise-ai-endpoints": "ts-node -P tests/tsconfig.json tests/enterprise-ai-endpoints.spec.ts",
    "test:enterprise-ai-http": "ts-node -P tests/tsconfig.json tests/enterprise-ai-http.spec.ts",
    "test:enterprise-ai-all": "npm run test:enterprise-ai && npm run test:enterprise-ai-endpoints && npm run test:enterprise-ai-http",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.2.35",
    "nodemailer": "^8.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "@types/ws": "^8.5.10",
    "prisma": "^5.10.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.2"
  }
}
